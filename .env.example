# ================== EXPENSE TRACKER - .env TEMPLATE ==================
# IMPORTANT: Never commit the .env file to version control!
# Copy this file to .env and fill in your actual values
# Add .env to your .gitignore file

# ============= FLASK CONFIGURATION =============
# Set to 'production' for production deployments, 'development' for local development
FLASK_ENV=production

# Debug mode: NEVER enable in production (only use for local development)
FLASK_DEBUG=False

# Secret key for session management - CHANGE THIS TO A RANDOM SECURE VALUE IN PRODUCTION
# Generate a random key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# ============= MONGODB ATLAS CONFIGURATION =============
# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database-name?appName=appname
# Steps to get your connection string:
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create a cluster and database user
# 3. Click "Connect" and copy the connection string
# 4. Replace placeholder values with your actual credentials
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/expense_tracker?appName=expensetracker

# Alternative database name if different from default
MONGO_DB_NAME=expense_tracker

# ============= EMAIL CONFIGURATION =============
# SendGrid for reliable email delivery on cloud platforms (Render, Heroku, etc.)
# SendGrid is MUCH more reliable than Gmail SMTP on cloud servers

# Steps to get SendGrid API Key:
# 1. Go to https://sendgrid.com/ and sign up for FREE account
# 2. Go to Settings → API Keys
# 3. Create new API Key with Full Access permissions
# 4. Copy the key below (keep it SECRET!)
# FREE TIER: 100 emails per day

SENDGRID_API_KEY=SG.your_sendgrid_api_key_here_replace_with_actual_key

# Email address to send OTPs from (FROM field in emails)
# This can be any email address, not necessarily Gmail
EXPENSE_TRACKER_EMAIL=your-sender-email@gmail.com

# ============= SERVER CONFIGURATION =============
# Port for local development (Render will automatically set PORT=443 or PORT=80)
PORT=5000

# ============= OPTIONAL: ADDITIONAL SECURITY =============
# Uncomment these for production deployments with SSL/HTTPS
# SESSION_COOKIE_SECURE=True
# SESSION_COOKIE_HTTPONLY=True
# SESSION_COOKIE_SAMESITE=Strict
